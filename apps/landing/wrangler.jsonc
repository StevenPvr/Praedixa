{
  "name": "praedixa-landing",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-02-05",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "routes": [
    { "pattern": "praedixa.com", "custom_domain": true },
    { "pattern": "www.praedixa.com", "custom_domain": true }
  ]
}
