# Praedixa API — Environment Variables
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────
# Use localhost:5433 when running API outside Docker (pnpm dev:api)
# Docker Compose overrides this to postgres:5432 (internal network)
DATABASE_URL=postgresql+asyncpg://praedixa:changeme@localhost:5433/praedixa

# ── Supabase Auth ─────────────────────────────────────
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here
SUPABASE_URL=https://your-project.supabase.co

# ── CORS ──────────────────────────────────────────────
# JSON list of allowed origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:3002","http://127.0.0.1:3000","http://127.0.0.1:3001","http://127.0.0.1:3002","http://[::1]:3000","http://[::1]:3001","http://[::1]:3002"]

# ── Application ───────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=debug
API_V1_PREFIX=/api/v1
APP_VERSION=0.1.0
LEGACY_HS256_ENABLED=false
ALLOW_DEV_ISSUER_FALLBACK=false
ALLOW_DEV_USER_METADATA_ORG_ID=false
RATE_LIMIT_STORAGE_URI=

# ── Key Management ────────────────────────────────
# "local" for dev (derives from seed), "scaleway" for production
KEY_PROVIDER=local
# At least 16 chars. Only used when KEY_PROVIDER=local.
LOCAL_KEY_SEED=praedixa-dev-seed-change-me-in-prod

# ── Data Foundation ──────────────────────────────
PLATFORM_SCHEMA=platform
RAW_SCHEMA_SUFFIX=raw
TRANSFORMED_SCHEMA_SUFFIX=transformed
MAX_DATASETS_PER_ORG=50
MAX_COLUMNS_PER_TABLE=200
MAX_WINDOWS_PER_DATASET=10
MIN_WINDOW_SIZE=1
MAX_WINDOW_SIZE=365
DEFAULT_LOOKBACK_DAYS=60

# ── Scaleway Secrets Manager (production only) ────
# Required when KEY_PROVIDER=scaleway
# SCW_SECRET_KEY=your-scaleway-api-key
# SCW_DEFAULT_PROJECT_ID=your-scaleway-project-id
# SCW_REGION=fr-par

# ── Production — Render + Neon ────────────────────────
# Render free tier (Python native) + Neon serverless PostgreSQL
#
# DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>.neon.tech/praedixa?sslmode=require
# SUPABASE_JWT_SECRET=<min 32 chars, from Supabase dashboard>
# SUPABASE_URL=https://your-project.supabase.co
# CORS_ORIGINS=["https://app.praedixa.com"]
# ENVIRONMENT=production
# DEBUG=false
# LOG_LEVEL=info
