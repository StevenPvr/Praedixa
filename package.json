{
  "name": "praedixa",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @praedixa/landing dev",
    "dev:landing": "pnpm --filter @praedixa/landing dev",
    "dev:webapp": "pnpm --filter @praedixa/webapp dev",
    "dev:admin": "pnpm --filter @praedixa/admin dev",
    "dev:api": "cd app-api && uv run alembic upgrade head && uv run uvicorn app.main:app --reload --port 8000",
    "dev:api:setup": "./scripts/dev-setup.sh",
    "build": "pnpm --filter @praedixa/shared-types build && pnpm --filter @praedixa/ui build && pnpm --filter @praedixa/landing build && pnpm --filter @praedixa/webapp build && pnpm --filter @praedixa/admin build",
    "build:landing": "pnpm --filter @praedixa/landing build",
    "build:webapp": "pnpm --filter @praedixa/webapp build",
    "build:admin": "pnpm --filter @praedixa/admin build",
    "lint": "pnpm --filter @praedixa/shared-types lint && pnpm --filter @praedixa/ui lint && pnpm --filter @praedixa/landing lint && pnpm --filter @praedixa/webapp lint && pnpm --filter @praedixa/admin lint",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "pnpm test:coverage",
    "e2e:ports:free": "bash ./scripts/e2e-free-ports.sh",
    "test:e2e": "pnpm e2e:ports:free && PW_REUSE_SERVER=0 playwright test",
    "test:e2e:landing": "pnpm e2e:ports:free && PW_REUSE_SERVER=0 playwright test --project=landing",
    "test:e2e:webapp": "pnpm e2e:ports:free && PW_REUSE_SERVER=0 playwright test --project=webapp",
    "test:e2e:webapp:visual": "pnpm e2e:ports:free && PW_REUSE_SERVER=0 playwright test testing/e2e/webapp/visual-qa-premium.spec.ts --project=webapp --workers=1 --reporter=list",
    "test:e2e:webapp:visual:ci": "CI=1 playwright test testing/e2e/webapp/visual-qa-premium.spec.ts --project=webapp --workers=1 --reporter=list",
    "test:e2e:admin": "pnpm e2e:ports:free && PW_REUSE_SERVER=0 playwright test --project=admin",
    "test:e2e:smoke": "pnpm e2e:ports:free && PW_REUSE_SERVER=0 playwright test testing/e2e/admin/smoke.spec.ts --project=admin --workers=1 --reporter=list",
    "test:e2e:coverage": "pnpm e2e:ports:free && PW_REUSE_SERVER=0 COVERAGE=1 playwright test",
    "test:e2e:ci": "CI=1 COVERAGE=1 playwright test",
    "ci:strict": "pnpm lint && pnpm build && pnpm typecheck && pnpm test:ci && pnpm test:e2e:ci",
    "typecheck": "tsc --build",
    "cf:build": "pnpm --filter @praedixa/landing cf:build",
    "preview": "pnpm --filter @praedixa/landing preview",
    "deploy": "pnpm --filter @praedixa/landing run deploy && pnpm --filter @praedixa/webapp run deploy",
    "deploy:landing": "pnpm --filter @praedixa/landing run deploy",
    "deploy:webapp": "pnpm --filter @praedixa/webapp run deploy",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo clean && rm -rf node_modules",
    "pre-commit": "prek run --all-files",
    "postinstall": "sh scripts/install-prek.sh"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19.0.0",
      "@types/react-dom": "^19.0.0",
      "tailwindcss": "3.4.19"
    }
  },
  "devDependencies": {
    "@hibryda/count-sloc-h": "^0.0.1",
    "@playwright/test": "^1.58.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.0.0",
    "esm": "^3.2.25",
    "jsdom": "^26.0.0",
    "monocart-reporter": "^2.10.0",
    "prettier": "^3.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.4"
  }
}
