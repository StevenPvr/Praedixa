{
  "name": "@praedixa/shared-types",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./api-client": {
      "types": "./dist/api-client.d.ts",
      "import": "./dist/api-client.js"
    },
    "./api": {
      "types": "./dist/api.d.ts",
      "import": "./dist/api.js"
    },
    "./public-contract-node": {
      "types": "./dist/api/public-contract/openapi-node.d.ts",
      "import": "./dist/api/public-contract/openapi-node.js"
    },
    "./domain": {
      "types": "./dist/domain.d.ts",
      "import": "./dist/domain.js"
    },
    "./oidc-discovery": {
      "types": "./dist/oidc-discovery.d.ts",
      "import": "./dist/oidc-discovery.js"
    }
  },
  "scripts": {
    "build": "tsc --build --force",
    "dev": "tsc --build --watch",
    "lint": "eslint --max-warnings=0 src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "yaml": "^2.8.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
