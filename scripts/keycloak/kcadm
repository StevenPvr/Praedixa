#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
KCADM_SH="$REPO_ROOT/.meta/.tools/keycloak-26.5.3/bin/kcadm.sh"

if [ ! -x "$KCADM_SH" ]; then
  echo "kcadm not installed at: $KCADM_SH" >&2
  echo "Install Keycloak release under .meta/.tools first." >&2
  exit 1
fi

exec "$KCADM_SH" "$@"
