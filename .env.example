# =============================================================================
# Praedixa Landing — Variables d'environnement
# =============================================================================
# Copier ce fichier vers .env.local et remplir les valeurs.
# .env.local est ignoré par git (voir .gitignore ligne 9).
# =============================================================================

NODE_ENV=development

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Contact
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CONTACT_EMAIL=contact@praedixa.com

# -----------------------------------------------------------------------------
# Sentry — Error tracking & monitoring (disabled — re-enable with @sentry/cloudflare)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.de.sentry.io/0
# SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SENTRY_ORG=praedixa
# SENTRY_PROJECT=landing
