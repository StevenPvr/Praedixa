{
  "name": "@praedixa/webapp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack --port 3001",
    "build": "next build --webpack",
    "start": "next start",
    "test": "vitest run --config vitest.config.ts",
    "lint": "eslint --max-warnings=0 app/ components/ lib/",
    "typecheck": "tsc --noEmit",
    "cf:build": "opennextjs-cloudflare build",
    "preview": "pnpm cf:build && opennextjs-cloudflare preview",
    "deploy": "pnpm cf:build && opennextjs-cloudflare deploy",
    "deploy:scw:staging": "../scripts/scw/scw-deploy-frontend.sh webapp staging",
    "deploy:scw:prod": "../scripts/scw/scw-deploy-frontend.sh webapp prod"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@praedixa/api-hooks": "workspace:*",
    "@praedixa/shared-types": "workspace:*",
    "@praedixa/ui": "workspace:*",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "date-fns": "^4.1.0",
    "next": "16.1.7",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@opennextjs/cloudflare": "^1.17.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.3",
    "wrangler": "^4.65.0"
  }
}
