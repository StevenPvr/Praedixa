              "warn",
              {
                "minScore": 0.9
              }
            ],
            "largest-contentful-paint": [
              "error",
              {
                "maxNumericValue": 2500
              }
            ],
            "cumulative-layout-shift": [
              "error",
              {
                "maxNumericValue": 0.1
              }
            ],
            "total-blocking-time": [
              "warn",
              {
                "maxNumericValue": 300
              }
            ]
          }
        },
        {
          "matchingUrlPattern": "http://127\\.0\\.0\\.1:300[12]/login$",
          "assertions": {
            "categories:performance": [
              "error",
              {
                "minScore": 0.9
              }
            ],
            "largest-contentful-paint": [
              "error",
              {
                "maxNumericValue": 2500
              }
            ],
            "cumulative-layout-shift": [
              "error",
              {
                "maxNumericValue": 0.1
              }
            ],
            "total-blocking-time": [
              "error",
              {
                "maxNumericValue": 300
              }
            ]
          }
        }
      ]
    }
