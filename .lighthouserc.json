{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "url": [
        "http://127.0.0.1:3000/fr",
        "http://127.0.0.1:3001/login",
        "http://127.0.0.1:3002/login"
      ],
      "settings": {
        "chromeFlags": "--no-sandbox --disable-dev-shm-usage"
      }
    },
    "assert": {
