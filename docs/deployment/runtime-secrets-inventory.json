          "required_in_preflight": true,
          "keys": ["LANDING_ASSET_SIGNING_SECRET"],
          "purpose": "landing short-lived asset URL signing secret"
        }
      ]
    },
    {
      "service_id": "webapp-staging",
      "environment": "staging",
      "service": "webapp",
      "namespace_name": "webapp-staging",
      "container_name": "webapp-staging",
      "secret_path_prefix": "/praedixa/staging/webapp-staging/runtime",
      "owner": "Front produit",
      "reviewers": ["Platform TS", "Infra/DevOps"],
      "rotation_sla_days": 90,
      "preflight_required": true,
      "public_origin": {
        "required_in_preflight": true,
        "env_keys": ["AUTH_APP_ORIGIN", "NEXT_PUBLIC_APP_ORIGIN"],
        "expected_origin": "https://staging-app.praedixa.com",
        "purpose": "webapp public origin for OIDC redirects and same-origin enforcement"
      },
      "secret_groups": [
        {
          "mode": "all_of",
          "required_in_preflight": true,
          "keys": ["AUTH_SESSION_SECRET"],
          "purpose": "webapp session cookie signing"
        },
        {
          "mode": "any_of",
          "required_in_preflight": true,
          "keys": ["AUTH_RATE_LIMIT_REDIS_URL", "RATE_LIMIT_STORAGE_URI"],
          "purpose": "webapp distributed auth rate limit storage"
        },
        {
          "mode": "all_of",
          "required_in_preflight": true,
          "keys": ["AUTH_RATE_LIMIT_KEY_SALT"],
          "purpose": "webapp auth rate limit key derivation"
        },
        {
          "mode": "all_of",
          "required_in_preflight": false,
          "keys": ["AUTH_OIDC_CLIENT_SECRET"],
          "purpose": "optional confidential OIDC client secret"
        }
      ]
    },
