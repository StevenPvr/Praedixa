{
  "inventory_type": "runtime-secrets",
  "schema_version": "1",
  "services": [
    {
      "service_id": "landing-staging",
      "environment": "staging",
      "service": "landing",
      "namespace_name": "landing-staging",
      "container_name": "landing-staging",
      "secret_path_prefix": "/praedixa/staging/landing-staging/runtime",
      "owner": "Front marketing",
      "reviewers": ["Infra/DevOps", "Security review pour secrets formulaire"],
      "rotation_sla_days": 90,
      "preflight_required": true,
      "secret_groups": [
        {
          "mode": "all_of",
          "required_in_preflight": true,
          "keys": ["CONTACT_API_INGEST_TOKEN"],
          "purpose": "landing contact form ingest authentication"
        },
        {
          "mode": "all_of",
          "required_in_preflight": true,
          "keys": ["RESEND_API_KEY"],
          "purpose": "landing transactional email delivery"
        },
        {
          "mode": "all_of",
          "required_in_preflight": true,
          "keys": ["RATE_LIMIT_STORAGE_URI"],
          "purpose": "landing distributed abuse protection storage"
        },
        {
          "mode": "all_of",
          "required_in_preflight": true,
          "keys": ["CONTACT_FORM_CHALLENGE_SECRET"],
          "purpose": "landing human verification challenge secret"
        },
        {
          "mode": "all_of",
          "required_in_preflight": true,
          "keys": ["LANDING_ASSET_SIGNING_SECRET"],
          "purpose": "landing short-lived asset URL signing secret"
        }
      ]
    },
    {
      "service_id": "landing-prod",
      "environment": "prod",
      "service": "landing",
      "namespace_name": "landing-prod",
      "container_name": "landing-web",
      "secret_path_prefix": "/praedixa/prod/landing-web/runtime",
      "owner": "Front marketing",
      "reviewers": ["Infra/DevOps", "Security review pour secrets formulaire"],
      "rotation_sla_days": 90,
      "preflight_required": true,
      "secret_groups": [
        {
          "mode": "all_of",
          "required_in_preflight": true,
          "keys": ["CONTACT_API_INGEST_TOKEN"],
          "purpose": "landing contact form ingest authentication"
        },
        {
          "mode": "all_of",
          "required_in_preflight": true,
