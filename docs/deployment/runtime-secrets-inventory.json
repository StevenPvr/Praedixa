          "purpose": "landing transactional email delivery"
        },
        {
          "mode": "all_of",
          "required_in_preflight": true,
          "keys": ["RATE_LIMIT_STORAGE_URI"],
          "purpose": "landing distributed abuse protection storage"
        },
        {
          "mode": "all_of",
          "required_in_preflight": true,
          "keys": ["CONTACT_FORM_CHALLENGE_SECRET"],
