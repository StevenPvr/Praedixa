{
  "name": "@praedixa/landing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "clean:dev-cache": "rm -rf .next .turbo",
    "dev:fresh": "pnpm clean:dev-cache && next dev",
    "dev:webpack:fresh": "pnpm clean:dev-cache && next dev --webpack",
    "dev:turbopack": "next dev --turbopack",
    "resend:check": "node ./scripts/check-resend-readiness.mjs",
    "build": "next build --webpack",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint --max-warnings=0 app/ components/ lib/ proxy.ts next.config.ts open-next.config.ts",
    "typecheck": "tsc --noEmit",
    "cf:build": "opennextjs-cloudflare build",
    "preview": "pnpm cf:build && opennextjs-cloudflare preview",
    "deploy": "pnpm resend:check && pnpm cf:build && opennextjs-cloudflare deploy",
    "deploy:scw:prod": "cd .. && ./scripts/scw-deploy-landing.sh prod",
    "deploy:scw:staging": "cd .. && ./scripts/scw-deploy-landing.sh staging",
    "dev:webpack": "next dev --webpack",
    "blog:audit-links": "node ./scripts/audit-blog-links.mjs",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "@opennextjs/cloudflare": "^1.17.1",
    "@phosphor-icons/react": "^2.1.10",
    "@praedixa/shared-types": "workspace:*",
    "@praedixa/ui": "workspace:*",
    "clsx": "^2.1.0",
    "framer-motion": "^12.31.0",
    "geist": "^1.7.0",
    "gray-matter": "^4.0.3",
    "next": "16.1.5",
    "reading-time": "^1.5.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "resend": "^6.9.3",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^15.5.11",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "sharp": "^0.34.5",
    "tailwindcss": "3.4.19",
    "typescript": "^5.7.3",
    "wrangler": "^4.65.0"
  }
}
