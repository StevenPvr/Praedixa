{
  "name": "@praedixa/landing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:turbopack": "next dev --turbopack",
    "resend:check": "node ./scripts/check-resend-readiness.mjs",
    "build": "next build --webpack",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint app/ components/ lib/ proxy.ts proxy.node.ts next.config.ts open-next.config.ts",
    "typecheck": "tsc --noEmit",
    "cf:build": "opennextjs-cloudflare build",
    "preview": "pnpm cf:build && opennextjs-cloudflare preview",
    "deploy": "pnpm resend:check && pnpm cf:build && opennextjs-cloudflare deploy",
    "dev:webpack": "next dev"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.16.0",
    "@phosphor-icons/react": "^2.1.10",
    "@praedixa/shared-types": "workspace:*",
    "@praedixa/ui": "workspace:*",
    "clsx": "^2.1.0",
    "framer-motion": "^12.31.0",
    "geist": "^1.7.0",
    "next": "16.1.5",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "resend": "^6.9.1",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^15.5.11",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.183.0",
    "autoprefixer": "^10.4.19",
    "glsl-noise": "^0.0.0",
    "glslify-loader": "^2.0.0",
    "postcss": "^8.4.38",
    "raw-loader": "^4.0.2",
    "sharp": "^0.34.5",
    "tailwindcss": "3.4.19",
    "typescript": "^5.7.3",
    "wrangler": "^4.0.0"
  }
}
