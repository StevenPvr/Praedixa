{
  "realm": "praedixa",
  "enabled": true,
  "displayName": "Praedixa",
  "sslRequired": "external",
  "registrationAllowed": false,
  "registrationEmailAsUsername": false,
  "rememberMe": true,
  "verifyEmail": false,
  "emailTheme": "praedixa",
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "smtpServer": {
    "from": "hello@praedixa.com",
    "fromDisplayName": "Praedixa"
  },
  "browserFlow": "browser",
  "otpPolicyType": "totp",
  "otpPolicyAlgorithm": "HmacSHA1",
  "otpPolicyInitialCounter": 0,
  "otpPolicyDigits": 6,
  "otpPolicyLookAheadWindow": 1,
  "otpPolicyPeriod": 30,
  "otpPolicyCodeReusable": false,
  "requiredActions": [
    {
      "alias": "CONFIGURE_TOTP",
      "name": "Configure OTP",
      "providerId": "CONFIGURE_TOTP",
      "enabled": true,
      "defaultAction": false,
      "priority": 10,
      "config": {}
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "super_admin"
      },
      {
        "name": "org_admin"
      },
      {
        "name": "hr_manager"
      },
      {
        "name": "manager"
      },
      {
        "name": "employee"
      },
      {
        "name": "viewer"
      }
    ]
  },
  "clients": [
    {
      "clientId": "praedixa-webapp",
      "name": "Praedixa Webapp",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:3001/auth/callback",
        "https://staging-app.praedixa.com/auth/callback",
        "https://app.praedixa.com/auth/callback"
      ],
      "webOrigins": [
        "http://localhost:3001",
        "https://staging-app.praedixa.com",
        "https://app.praedixa.com"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "audience-praedixa-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "praedixa-api",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "introspection.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        },
        {
          "name": "claim-role",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "role",
            "claim.name": "role",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "introspection.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        },
        {
          "name": "claim-organization-id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "organization_id",
            "claim.name": "organization_id",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "introspection.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        },
        {
          "name": "claim-site-id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "site_id",
            "claim.name": "site_id",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "introspection.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        }
      ]
    },
    {
      "clientId": "praedixa-admin",
      "name": "Praedixa Admin",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:3002/auth/callback",
        "https://staging-admin.praedixa.com/auth/callback",
        "https://admin.praedixa.com/auth/callback"
      ],
      "webOrigins": [
        "http://localhost:3002",
        "https://staging-admin.praedixa.com",
        "https://admin.praedixa.com"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "audience-praedixa-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "praedixa-api",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "introspection.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        },
        {
          "name": "claim-role",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "role",
            "claim.name": "role",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "introspection.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        },
        {
          "name": "claim-organization-id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "organization_id",
            "claim.name": "organization_id",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "introspection.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        },
        {
          "name": "claim-site-id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "site_id",
            "claim.name": "site_id",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "introspection.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        },
        {
          "name": "claim-permissions",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "permissions",
            "claim.name": "permissions",
            "jsonType.label": "String",
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "introspection.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        },
        {
          "name": "claim-amr",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-amr-mapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true",
            "id.token.claim": "false",
            "introspection.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        }
      ]
    },
    {
      "clientId": "praedixa-api",
      "name": "Praedixa API",
      "enabled": true,
      "protocol": "openid-connect",
      "bearerOnly": true
    }
  ]
}
