{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "https://schemas.praedixa.dev/contracts/decisionops/approval.schema.json",
  "title": "Praedixa Approval",
  "description": "Versioned approval record for recommendation validation, matrix routing and structured justification.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schema_version",
    "approval_id",
    "contract_id",
    "contract_version",
    "recommendation_id",
    "status",
    "scope",
    "requested_at",
    "requested_by",
    "rule",
    "policy_context",
    "separation_of_duties"
  ],
  "properties": {
    "kind": {
      "const": "Approval"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "approval_id": {
      "$ref": "#/$defs/uuid"
    },
    "contract_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{2,127}$"
    },
    "contract_version": {
      "type": "integer",
      "minimum": 1
    },
    "recommendation_id": {
      "$ref": "#/$defs/uuid"
    },
    "scenario_run_id": {
      "$ref": "#/$defs/uuid"
    },
    "status": {
      "enum": ["requested", "granted", "rejected", "expired", "canceled"]
    },
    "scope": {
      "$ref": "#/$defs/scope"
    },
    "requested_at": {
      "type": "string",
      "format": "date-time"
    },
    "deadline_at": {
      "type": "string",
      "format": "date-time"
    },
    "requested_by": {
      "$ref": "#/$defs/actorRef"
    },
    "rule": {
      "$ref": "#/$defs/approvalRule"
    },
    "policy_context": {
      "$ref": "#/$defs/policyContext"
    },
    "decision": {
      "$ref": "#/$defs/decision"
    },
    "separation_of_duties": {
      "$ref": "#/$defs/separationOfDuties"
    },
    "notes": {
      "type": "string",
      "maxLength": 1000
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "enum": ["granted", "rejected"]
          }
        }
      },
      "then": {
        "required": ["decision"]
      }
    }
  ],
  "$defs": {
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entity_type", "selector", "horizon_id"],
      "properties": {
        "entity_type": {
          "enum": [
            "organization",
            "site",
            "team",
            "flow",
            "route",
            "order_aggregate",
            "stock_node",
            "period"
          ]
        },
        "selector": {
          "$ref": "#/$defs/selector"
        },
        "horizon_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9+_-]{0,31}$"
        }
      }
    },
    "selector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": {
          "enum": ["all", "ids", "query"]
        },
        "ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "uniqueItems": true
        },
        "query": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        }
      }
    },
    "actorRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor_type", "actor_id"],
      "properties": {
        "actor_type": {
          "enum": ["user", "system", "service"]
        },
        "actor_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "actor_role": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_.-]{1,63}$"
        }
      }
    },
    "approvalRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_id", "step_order", "approver_role"],
      "properties": {
        "rule_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_.-]{1,63}$"
        },
        "step_order": {
          "type": "integer",
          "minimum": 1
        },
        "approver_role": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_.-]{1,63}$"
        },
        "deadline_hours": {
          "type": "integer",
          "minimum": 1,
          "maximum": 720
        }
      }
    },
    "policyContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_types"],
      "properties": {
        "estimated_cost_eur": {
          "type": "number",
          "minimum": 0
        },
        "risk_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "action_types": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_.-]{1,63}$"
          },
          "uniqueItems": true
        },
        "destination_types": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_.-]{1,63}$"
          },
          "uniqueItems": true
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "outcome",
        "actor_user_id",
        "actor_role",
        "reason_code",
        "decided_at"
      ],
      "properties": {
        "outcome": {
          "enum": ["granted", "rejected", "overridden"]
        },
        "actor_user_id": {
          "$ref": "#/$defs/uuid"
        },
        "actor_role": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_.-]{1,63}$"
        },
        "reason_code": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_.-]{1,63}$"
        },
        "comment": {
          "type": "string",
          "maxLength": 1000
        },
        "decided_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "separationOfDuties": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "satisfied"],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "satisfied": {
          "type": "boolean"
        },
        "requester_actor_id": {
          "type": "string",
          "maxLength": 120
        },
        "approver_actor_id": {
          "type": "string",
          "maxLength": 120
        }
      }
    }
  }
}
