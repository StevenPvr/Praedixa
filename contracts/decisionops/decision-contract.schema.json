{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "https://schemas.praedixa.dev/contracts/decisionops/decision-contract.schema.json",
  "title": "Praedixa Decision Contract",
  "description": "Versioned DecisionOps contract definition for a governed family of operational arbitrage.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schema_version",
    "contract_id",
    "contract_version",
    "name",
    "pack",
    "status",
    "graph_ref",
    "scope",
    "inputs",
    "objective",
    "decision_variables",
    "hard_constraints",
    "soft_constraints",
    "approvals",
    "actions",
    "policy_hooks",
    "roi_formula",
    "explanation_template",
    "audit"
  ],
  "properties": {
    "kind": {
      "const": "DecisionContract"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "contract_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{2,127}$"
    },
    "contract_version": {
      "type": "integer",
      "minimum": 1
    },
    "name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 160
    },
    "description": {
      "type": "string",
      "maxLength": 2000
    },
    "organization_id": {
      "$ref": "#/$defs/uuid"
    },
    "workspace_id": {
      "$ref": "#/$defs/uuid"
    },
    "pack": {
      "$ref": "#/$defs/pack"
    },
    "status": {
      "enum": ["draft", "testing", "approved", "published", "archived"]
    },
    "template_ref": {
      "$ref": "#/$defs/templateRef"
    },
    "graph_ref": {
      "$ref": "#/$defs/graphRef"
    },
    "scope": {
      "$ref": "#/$defs/scope"
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/inputRef"
      }
    },
    "objective": {
      "$ref": "#/$defs/objective"
    },
    "decision_variables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/decisionVariable"
      }
    },
    "hard_constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/hardConstraint"
      }
    },
    "soft_constraints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/softConstraint"
      }
    },
    "approvals": {
      "$ref": "#/$defs/approvals"
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/allowedAction"
      }
    },
    "policy_hooks": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9_.-]{1,127}$"
      },
      "uniqueItems": true
    },
    "roi_formula": {
      "$ref": "#/$defs/roiFormula"
    },
    "explanation_template": {
      "$ref": "#/$defs/explanationTemplate"
    },
    "validation": {
      "$ref": "#/$defs/validation"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9:_-]{1,63}$"
      },
      "uniqueItems": true
    },
    "audit": {
      "$ref": "#/$defs/audit"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "published"
          }
        }
      },
      "then": {
        "properties": {
          "audit": {
            "allOf": [
              {
                "$ref": "#/$defs/audit"
              },
              {
                "required": ["published_at"]
              }
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
    },
    "pack": {
      "enum": ["coverage", "flow", "allocation", "core"]
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entity_type", "selector", "horizon_id"],
      "properties": {
        "entity_type": {
          "enum": [
            "organization",
            "site",
            "team",
            "flow",
            "route",
            "order_aggregate",
            "stock_node",
            "period"
          ]
        },
        "selector": {
          "$ref": "#/$defs/selector"
        },
        "horizon_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9+_-]{0,31}$"
        },
        "dimensions": {
          "type": "object",
          "propertyNames": {
            "pattern": "^[a-z0-9][a-z0-9_.-]{1,63}$"
          },
          "additionalProperties": {
            "type": "string",
            "maxLength": 120
          }
        }
      }
    },
    "selector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": {
          "enum": ["all", "ids", "query"]
        },
        "ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "uniqueItems": true
        },
        "query": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        }
      }
    },
    "templateRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["template_id", "template_version"],
      "properties": {
        "template_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]{2,127}$"
        },
        "template_version": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "graphRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["graph_id", "graph_version"],
      "properties": {
        "graph_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]{2,127}$"
        },
        "graph_version": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "inputRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "source_type", "source_ref", "required"],
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_.-]{1,63}$"
        },
        "source_type": {
          "enum": ["metric", "entity", "dataset", "signal", "parameter"]
        },
        "source_ref": {
          "type": "string",
          "minLength": 3,
          "maxLength": 200
        },
        "required": {
          "type": "boolean"
        },
        "description": {
          "type": "string",
          "maxLength": 500
        }
      }
    },
    "objective": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_metric", "optimization_mode", "weights"],
      "properties": {
        "primary_metric": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_.-]{1,127}$"
        },
        "optimization_mode": {
          "enum": ["minimize", "maximize", "balance"]
        },
        "weights": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "pattern": "^[a-z0-9][a-z0-9_.-]{1,63}$"
          },
          "additionalProperties": {
            "type": "number",
            "minimum": 0
          }
        },
        "secondary_metrics": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_.-]{1,127}$"
          },
          "uniqueItems": true
        }
      }
    },
    "decisionVariable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "label", "value_type"],
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_.-]{1,63}$"
        },
        "label": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "value_type": {
          "enum": ["boolean", "integer", "number", "string", "enum"]
        },
        "allowed_values": {
          "type": "array",
          "items": {
            "type": ["string", "number", "integer", "boolean"]
          },
          "uniqueItems": true
        },
        "unit": {
          "type": "string",
          "maxLength": 32
        },
        "description": {
          "type": "string",
          "maxLength": 500
        }
      }
    },
    "hardConstraint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "expression"],
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_.-]{1,63}$"
        },
        "expression": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "description": {
          "type": "string",
          "maxLength": 500
        },
        "source_ref": {
          "type": "string",
          "maxLength": 200
        }
      }
    },
    "softConstraint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "expression"],
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_.-]{1,63}$"
        },
        "expression": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "weight": {
          "type": "number",
          "minimum": 0
        },
        "description": {
          "type": "string",
          "maxLength": 500
        }
      }
    },
    "approvals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "matrix", "separation_of_duties"],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "default_deadline_hours": {
          "type": "integer",
          "minimum": 1,
          "maximum": 720
        },
        "matrix": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/approvalRule"
          }
        },
        "separation_of_duties": {
          "type": "boolean"
        }
      }
    },
    "approvalRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_id", "step_order", "approver_role"],
      "properties": {
        "rule_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_.-]{1,63}$"
        },
        "step_order": {
          "type": "integer",
          "minimum": 1
        },
        "approver_role": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_.-]{1,63}$"
        },
        "deadline_hours": {
          "type": "integer",
          "minimum": 1,
          "maximum": 720
        },
        "when": {
          "$ref": "#/$defs/approvalTrigger"
        }
      }
    },
    "approvalTrigger": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "min_cost_eur": {
          "type": "number",
          "minimum": 0
        },
        "max_cost_eur": {
          "type": "number",
          "minimum": 0
        },
        "min_risk_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "max_risk_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "action_types": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_.-]{1,63}$"
          },
          "uniqueItems": true
        }
      }
    },
    "allowedAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_type", "destination_type"],
      "properties": {
        "action_type": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_.-]{1,63}$"
        },
        "destination_type": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_.-]{1,63}$"
        },
        "template_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]{2,127}$"
        },
        "requires_acknowledgement": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "roiFormula": {
      "type": "object",
      "additionalProperties": false,
      "required": ["language", "expression", "components", "currency"],
      "properties": {
        "language": {
          "const": "praedixa-expression/v1"
        },
        "expression": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        },
        "components": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/roiComponent"
          }
        }
      }
    },
    "roiComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "kind"],
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_.-]{1,63}$"
        },
        "label": {
          "type": "string",
          "maxLength": 120
        },
        "kind": {
          "enum": ["benefit", "cost"]
        },
        "source_ref": {
          "type": "string",
          "maxLength": 200
        }
      }
    },
    "explanationTemplate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["top_driver_keys", "binding_constraint_keys"],
      "properties": {
        "top_driver_keys": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_.-]{1,63}$"
          },
          "uniqueItems": true
        },
        "binding_constraint_keys": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_.-]{1,63}$"
          },
          "uniqueItems": true
        },
        "narrative_template": {
          "type": "string",
          "maxLength": 1000
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "last_replayed_at": {
          "type": "string",
          "format": "date-time"
        },
        "replay_window_days": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3650
        },
        "last_result": {
          "enum": ["passed", "failed", "warning"]
        }
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created_at", "created_by", "change_reason"],
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "created_by": {
          "$ref": "#/$defs/uuid"
        },
        "published_at": {
          "type": "string",
          "format": "date-time"
        },
        "change_reason": {
          "type": "string",
          "minLength": 3,
          "maxLength": 1000
        },
        "rollback_from_contract_version": {
          "type": "integer",
          "minimum": 1
        },
        "notes": {
          "type": "string",
          "maxLength": 1000
        }
      }
    }
  }
}
