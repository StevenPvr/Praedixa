# =============================================================================
# Praedixa - Git Ignore
# =============================================================================

# -----------------------------------------------------------------------------
# Environnement
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
!.env.example

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
# Python lib folders (but not apps/*/lib which is source code)
/lib/
lib64/
!apps/*/lib/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.venv/
venv/
ENV/
.uv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml
*.cover

# -----------------------------------------------------------------------------
# Node.js
# -----------------------------------------------------------------------------
node_modules/
.pnpm-store/
.turbo/
.next/
out/
dist/
*.tsbuildinfo
.open-next/
.wrangler/
.dev.vars

# -----------------------------------------------------------------------------
# IDEs
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
coverage/
.nyc_output/

# -----------------------------------------------------------------------------
# Data & ML (ne pas commit les données/modèles)
# -----------------------------------------------------------------------------
data/raw/
data/processed/
*.parquet
*.csv
!tests/fixtures/*.csv
*.pkl
*.joblib
mlruns/
mlartifacts/

# -----------------------------------------------------------------------------
# Infrastructure
# -----------------------------------------------------------------------------
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl

# -----------------------------------------------------------------------------
# Secrets (jamais commit)
# -----------------------------------------------------------------------------
*.pem
*.key
secrets/
credentials.json

# Claude Code
.claude/
.mcp.json
