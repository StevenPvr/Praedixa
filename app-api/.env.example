# Praedixa Data/ML Engine — Environment Variables
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────
# Use localhost:5433 when running data jobs outside Docker.
DATABASE_URL=postgresql+asyncpg://praedixa:praedixa_local_dev_pg_2026@localhost:5433/praedixa

# ── Runtime ───────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=debug
APP_VERSION=0.1.0
CONNECTORS_RUNTIME_URL=http://127.0.0.1:8100
# 32+ chars, shared only with internal workers/services.
CONNECTORS_RUNTIME_TOKEN=replace-with-internal-connectors-token
CONNECTORS_RUNTIME_TIMEOUT_SECONDS=10
# Comma-separated host allowlist; required outside development.
CONNECTORS_RUNTIME_ALLOWED_HOSTS=
CONNECTORS_RUNTIME_MAX_BATCH_SIZE=100

# ── Key Management ────────────────────────────────────
# "local" for dev (seed-derived), "scaleway" for staging/production.
KEY_PROVIDER=local
# Minimum 16 chars when KEY_PROVIDER=local.
LOCAL_KEY_SEED=praedixa-dev-seed-local-2026

# ── Data Foundation ───────────────────────────────────
PLATFORM_SCHEMA=platform
DATA_SCHEMA_SUFFIX=data
MAX_DATASETS_PER_ORG=50
MAX_COLUMNS_PER_TABLE=200
MAX_WINDOWS_PER_DATASET=10
MIN_WINDOW_SIZE=1
MAX_WINDOW_SIZE=365
DEFAULT_LOOKBACK_DAYS=60

# ── File Ingestion ────────────────────────────────────
MAX_UPLOAD_SIZE_BYTES=52428800
MAX_ROWS_PER_INGESTION=500000
UPLOAD_COOLDOWN_SECONDS=10

# ── Scaleway Secrets Manager (required when KEY_PROVIDER=scaleway)
# SCW_SECRET_KEY=your-scaleway-api-key
# SCW_DEFAULT_PROJECT_ID=your-scaleway-project-id
# SCW_REGION=fr-par
